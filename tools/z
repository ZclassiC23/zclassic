#!/bin/bash
# Copyright 2026 Rhett Creighton - Apache License 2.0
# z — tiny operator entry point for zclassic23.
#
# Designed for humans and AI/LLM tool calls: `z` alone returns the compact
# operator summary. Drill down only when the summary names a next step.
#
# SIMPLE:
#   z                            Compact agent/operator summary
#   z agent                      Same as above
#   z summary                    Same as above
#   z status                     Full healthcheck diagnostics
#
# CRUD pattern for drill-down: z <resource> [action] [params...]
#
# RESOURCES:
#   z block <height>              Read block at height
#   z block <height> <count>      Read N blocks
#   z blocks                      Chain tip height
#   z tx <txid>                   Read transaction UTXO detail
#   z balance                     Read all balances
#   z utxos                       List unspent transparent
#   z notes                       List unspent shielded
#   z addrs                       List all addresses
#   z zaddrs                      List shielded addresses
#   z mempool                     Mempool status
#   z peers                       Connected peers
#   z chain                       Chain summary stats
#   z state <subsystem> [key]     Generic dumpstate diagnostics
#   z log <pattern> [since max level]  Tail node.log via server-side regex
#   z sql <select> [limit]        SELECT-only node.db query
#   z tree                        Sapling tree state
#   z scan <start> <end>          Scan for commitments
#
# SEND:
#   z send <addr> <amount>        Send transparent
#   z zsend <from> <to> <amount>  Send shielded
#   z shield <from> <to> <amount> Shield (t→z)
#
# RAW:
#   z rpc <method> [args...]      Raw RPC call

set -e
CLI="$(dirname "$0")/../build/bin/zclassic-cli"
[ -x "$CLI" ] || CLI="./build/bin/zclassic-cli"
[ -x "$CLI" ] || { echo "zclassic-cli not found" >&2; exit 1; }

systemd_show_value() {
    local service="$1" prop="$2"
    command -v systemctl >/dev/null 2>&1 || return 1
    systemctl --user show "$service" -p "$prop" --value 2>/dev/null
}

systemd_exec_arg_service() {
    local service="$1" key="$2"
    command -v systemctl >/dev/null 2>&1 || return 1
    systemd_show_value "$service" ExecStart \
        | tr ' ' '\n' \
        | sed -n "s/^-${key}=//p" \
        | head -1
}

systemd_exec_arg() {
    local key="$1"
    systemd_exec_arg_service zclassic23 "$key"
}

DEFAULT_DATADIR="$HOME/.zclassic-c23"
DATADIR="${ZCL_DATADIR:-$DEFAULT_DATADIR}"
if [ -z "${ZCL_DATADIR:-}" ] && [ ! -f "$DATADIR/.cookie" ]; then
    SERVICE_DATADIR="$(systemd_exec_arg datadir || true)"
    if [ -n "$SERVICE_DATADIR" ] && [ -f "$SERVICE_DATADIR/.cookie" ]; then
        DATADIR="$SERVICE_DATADIR"
    fi
fi

RPCPORT="${ZCL_RPCPORT:-18232}"
if [ -z "${ZCL_RPCPORT:-}" ]; then
    SERVICE_RPCPORT="$(systemd_exec_arg rpcport || true)"
    if [ -n "$SERVICE_RPCPORT" ]; then
        RPCPORT="$SERVICE_RPCPORT"
    fi
fi

CLI_OPTS=("-datadir=$DATADIR" "-rpcport=$RPCPORT")
if [ -n "${ZCL_RPCCONNECT:-}" ]; then
    CLI_OPTS+=("-rpcconnect=$ZCL_RPCCONNECT")
fi

rpc() { "$CLI" "${CLI_OPTS[@]}" "$@" 2>/dev/null; }

api_summary_json() {
    local scheme host port url out
    scheme="${ZCL_API_SCHEME:-https}"
    host="${ZCL_API_HOST:-127.0.0.1}"
    port="${ZCL_API_PORT:-8443}"
    url="${scheme}://${host}:${port}/api/v1/agent"
    command -v curl >/dev/null 2>&1 || return 1
    out="$(curl -sk --max-time "${ZCL_API_TIMEOUT:-4}" "$url" 2>/dev/null || true)"
    if printf '%s\n' "$out" | grep -q '"schema"[[:space:]]*:[[:space:]]*"zcl.public_status.v1"'; then
        printf '%s\n' "$out"
        return 0
    fi
    return 1
}

agent_summary_json() {
    local out
    out="$(api_summary_json || true)"
    if [ -n "$out" ]; then
        printf '%s\n' "$out"
        return 0
    fi

    # Fallback for nodes without the HTTPS API bound. This is larger than the
    # public summary, but it keeps `z` useful over the same RPC target selection
    # logic as every other command.
    rpc healthcheck
}

json_field() {
    printf '%s\n' "$1" | sed -n "s/.*\"$2\"[[:space:]]*:[[:space:]]*\"\([^\"]*\)\".*/\1/p; s/.*\"$2\"[[:space:]]*:[[:space:]]*\([-0-9][0-9]*\).*/\1/p; s/.*\"$2\"[[:space:]]*:[[:space:]]*\(true\|false\).*/\1/p" | head -1
}

json_put_string() {
    local json="$1" key="$2" value="$3"
    if printf '%s\n' "$json" | grep -q "\"$key\"[[:space:]]*:"; then
        printf '%s\n' "$json" | sed "s/\"$key\"[[:space:]]*:[[:space:]]*\"[^\"]*\"/\"$key\":\"$value\"/g"
    else
        printf '%s\n' "$json" | sed "s/}$/,\"$key\":\"$value\"}/"
    fi
}

json_put_number() {
    local json="$1" key="$2" value="$3"
    if printf '%s\n' "$json" | grep -q "\"$key\"[[:space:]]*:"; then
        printf '%s\n' "$json" | sed "s/\"$key\"[[:space:]]*:[[:space:]]*[-0-9][0-9]*/\"$key\":$value/g; s/\"$key\"[[:space:]]*:[[:space:]]*null/\"$key\":$value/g"
    else
        printf '%s\n' "$json" | sed "s/}$/,\"$key\":$value}/"
    fi
}

json_put_bool() {
    local json="$1" key="$2" value="$3"
    if printf '%s\n' "$json" | grep -q "\"$key\"[[:space:]]*:"; then
        printf '%s\n' "$json" | sed "s/\"$key\"[[:space:]]*:[[:space:]]*\\(true\\|false\\|null\\)/\"$key\":$value/g"
    else
        printf '%s\n' "$json" | sed "s/}$/,\"$key\":$value}/"
    fi
}

json_put_null() {
    local json="$1" key="$2"
    if printf '%s\n' "$json" | grep -q "\"$key\"[[:space:]]*:"; then
        printf '%s\n' "$json" | sed "s/\"$key\"[[:space:]]*:[[:space:]]*\"[^\"]*\"/\"$key\":null/g; s/\"$key\"[[:space:]]*:[[:space:]]*[-0-9][0-9]*/\"$key\":null/g; s/\"$key\"[[:space:]]*:[[:space:]]*\\(true\\|false\\|null\\)/\"$key\":null/g"
    else
        printf '%s\n' "$json" | sed "s/}$/,\"$key\":null}/"
    fi
}

json_escape() {
    printf '%s' "$1" \
        | sed 's/\\/\\\\/g; s/"/\\"/g; s/	/\\t/g; s/\r/\\r/g' \
        | tr '\n' ' '
}

normalize_mirror_status_json() {
    local json="$1" lag blocker reachable lag_known lag_valid
    local candidate_lag_known candidate_lag_valid
    local legacy_height_known target_height_known
    reachable="$(json_field "$json" reachable)"
    lag="$(json_field "$json" candidate_lag)"
    [ -n "$lag" ] || lag="$(json_field "$json" lag)"
    [ -n "$lag" ] || lag=0
    lag_known="$(json_field "$json" lag_known)"
    lag_valid="$(json_field "$json" lag_valid)"
    candidate_lag_known="$(json_field "$json" candidate_lag_known)"
    candidate_lag_valid="$(json_field "$json" candidate_lag_valid)"
    legacy_height_known="$(json_field "$json" legacy_advisory_height_known)"
    target_height_known="$(json_field "$json" target_height_known)"
    [ -n "$lag_known" ] || lag_known="$candidate_lag_known"
    [ -n "$lag_valid" ] || lag_valid="$candidate_lag_valid"
    if [ "$reachable" != "true" ]; then
        lag=0
        lag_known=false
        lag_valid=false
        candidate_lag_known=false
        candidate_lag_valid=false
        legacy_height_known=false
        target_height_known=false
    elif [ -z "$lag_known" ]; then
        lag_known=true
    fi
    [ -n "$lag_valid" ] || lag_valid="$lag_known"
    [ -n "$candidate_lag_known" ] || candidate_lag_known="$lag_known"
    [ -n "$candidate_lag_valid" ] || candidate_lag_valid="$lag_valid"
    [ -n "$legacy_height_known" ] || legacy_height_known="$lag_known"
    [ -n "$target_height_known" ] || target_height_known="$lag_known"
    blocker="$(json_field "$json" candidate_blocker)"
    [ -n "$blocker" ] || blocker="$(json_field "$json" last_blocker_code)"
    [ -n "$blocker" ] || blocker="$(json_field "$json" activation_blocker)"
    active_detail=""
    if [ -n "$blocker" ]; then
        active_detail="$(json_field "$json" last_error)"
    fi

    json="$(json_put_string "$json" consensus_authority local_consensus_validation)"
    json="$(json_put_string "$json" candidate_source legacy_advisory)"
    json="$(json_put_string "$json" candidate_trust bounded_advisory_fallback)"
    json="$(json_put_bool "$json" lag_known "$lag_known")"
    json="$(json_put_bool "$json" lag_valid "$lag_valid")"
    json="$(json_put_bool "$json" candidate_lag_known "$candidate_lag_known")"
    json="$(json_put_bool "$json" candidate_lag_valid "$candidate_lag_valid")"
    json="$(json_put_bool "$json" legacy_advisory_height_known "$legacy_height_known")"
    json="$(json_put_bool "$json" target_height_known "$target_height_known")"
    json="$(json_put_number "$json" candidate_lag "$lag")"
    json="$(json_put_number "$json" lag "$lag")"
    if [ "$lag_known" = "true" ]; then
        json="$(json_put_number "$json" lag_observed "$lag")"
        json="$(json_put_number "$json" candidate_lag_observed "$lag")"
    else
        json="$(json_put_null "$json" lag_observed)"
        json="$(json_put_null "$json" candidate_lag_observed)"
    fi
    json="$(json_put_string "$json" candidate_blocker "$blocker")"
    json="$(json_put_string "$json" active_error_code "$blocker")"
    json="$(json_put_string "$json" active_error_detail "$active_detail")"
    printf '%s\n' "$json"
}

legacy_conf_value() {
    awk -F= -v k="$1" '
        $0 !~ /^[[:space:]]*[#;]/ {
            key=$1; val=$0; sub(/^[^=]*=/, "", val)
            gsub(/^[[:space:]]+|[[:space:]]+$/, "", key)
            gsub(/^[[:space:]]+|[[:space:]]+$/, "", val)
            if (key == k) { print val; exit }
        }' "${LEGACY_CONF:-$HOME/.zclassic/zclassic.conf}" 2>/dev/null
}

legacy_rpc() {
    local method="$1" params="${2:-[]}" user pass port body
    user="$(legacy_conf_value rpcuser)"
    pass="$(legacy_conf_value rpcpassword)"
    port="${LEGACY_RPCPORT:-${LEGACY_RPC_PORT:-$(legacy_conf_value rpcport)}}"
    port="${port:-8232}"
    [ -n "$user" ] && [ -n "$pass" ] || return 1
    body="{\"jsonrpc\":\"1.0\",\"id\":\"z-mirror\",\"method\":\"$method\",\"params\":$params}"
    curl -s --max-time 8 --user "$user:$pass" \
        -H 'content-type: application/json' \
        --data "$body" "http://127.0.0.1:$port/" 2>/dev/null
}

rpc_result() {
    local out
    out="$(rpc "$@" 2>/dev/null || true)"
    if printf '%s' "$out" | grep -q '"result"'; then
        json_field "$out" result
    else
        printf '%s' "$out"
    fi
}

mirror_fallback_json() {
    local c23_h c23_hash zd_resp zd_h zd_hash lag reachable observed_lag
    local blocker lag_known lag_valid
    c23_h="$(rpc_result getblockcount)"
    c23_hash=""
    if [ -n "$c23_h" ]; then
        c23_hash="$(rpc_result getblockhash "$c23_h")"
    fi
    zd_resp="$(legacy_rpc getblockchaininfo || true)"
    zd_h="$(json_field "$zd_resp" blocks)"
    if [ -n "$zd_h" ]; then
        zd_hash="$(json_field "$(legacy_rpc getblockhash "[$zd_h]" || true)" result)"
        reachable=true
    else
        zd_hash=""
        reachable=false
    fi
    if [ -n "$c23_h" ] && [ -n "$zd_h" ]; then
        lag=$((zd_h - c23_h))
        observed_lag="$lag"
        lag_known=true
        lag_valid=true
    else
        lag=0
        observed_lag=null
        lag_known=false
        lag_valid=false
    fi
    blocker=""
    [ "$reachable" = "true" ] || blocker="rpc-unreachable"
    printf '{"zclassic23_height":%s,"zclassic23_hash":"%s","zclassicd_height":%s,"zclassicd_hash":"%s","legacy_advisory_height_known":%s,"target_height_known":%s,"lag_known":%s,"lag_valid":%s,"lag":%s,"lag_observed":%s,"reachable":%s,"mirror_running":false,"last_catchup":0,"last_error":"fallback: getmirrorstatus unavailable","headers_added":0,"blocks_applied":0,"target_height":0,"authority_rewind_target":0,"last_advanced_height":0,"last_progress_blocks":0,"local_recovery_active":false,"legacy_advisory_gated_by_native_retries":false,"mirror_repair_gated_by_local_retries":false,"local_retries_exhausted":false,"local_missing_height":0,"local_retry_count":0,"local_distinct_peer_count":0,"local_peer_rotation_count":0,"stuck_height":0,"stuck_status_flags":0,"stuck_reason":"","stalls_total":0,"last_blocker_code":"%s","consensus_authority":"local_consensus_validation","candidate_source":"legacy_advisory","candidate_trust":"bounded_advisory_fallback","candidate_lag_known":%s,"candidate_lag_valid":%s,"candidate_lag":%s,"candidate_lag_observed":%s,"candidate_blocker":"%s","active_error_code":"%s","active_error_detail":"fallback: getmirrorstatus unavailable","override_active":false,"overrides_total":0,"unsafe_overrides_total":0,"blockers_total":0,"last_override_height":0,"last_override_safe":false,"last_override_scope":"","last_override_reason":"","activation_blocker":"%s","csr_sqlite_rc":0,"csr_failure_reason":""}\n' \
        "${c23_h:-0}" "$c23_hash" "${zd_h:-0}" "$zd_hash" \
        "$reachable" "$reachable" "$lag_known" "$lag_valid" \
        "$lag" "$observed_lag" "$reachable" "$blocker" \
        "$lag_known" "$lag_valid" "$lag" "$observed_lag" \
        "$blocker" "$blocker" "$blocker"
}

mirror_status_json() {
    local out
    out="$(rpc getmirrorstatus 2>/dev/null || true)"
    if [ -n "$out" ] && printf '%s' "$out" | grep -q 'zclassic23_height'; then
        normalize_mirror_status_json "$out"
    else
        mirror_fallback_json
    fi
}

topology_status_json() {
    local expected_c23_p2p expected_zd_p2p expected_c23_rpc expected_zd_rpc
    local c23_state c23_sub c23_pid c23_restarts c23_p2p c23_rpc c23_dd c23_snapshot
    local zd_state zd_sub zd_pid zd_restarts zd_p2p zd_rpc zd_dd
    local c23_net c23_chain c23_rf mirror zd_net zd_chain
    local c23_height c23_headers c23_hash c23_subver c23_conns c23_in c23_out c23_hs
    local c23_legacy c23_z23 c23_listening c23_addr_port hstar coins_applied blocker
    local zd_height zd_headers zd_hash zd_conns zd_addr_port
    local lag lag_known mirror_running reachable authority overrides
    local issues issue_count ok

    expected_c23_p2p="${ZCL_TOPOLOGY_C23_P2P:-8033}"
    expected_zd_p2p="${ZCL_TOPOLOGY_ZD_P2P:-8034}"
    expected_c23_rpc="${ZCL_TOPOLOGY_C23_RPC:-$RPCPORT}"
    expected_zd_rpc="${ZCL_TOPOLOGY_ZD_RPC:-8232}"

    c23_state="$(systemd_show_value zclassic23 ActiveState || true)"
    c23_sub="$(systemd_show_value zclassic23 SubState || true)"
    c23_pid="$(systemd_show_value zclassic23 MainPID || true)"
    c23_restarts="$(systemd_show_value zclassic23 NRestarts || true)"
    c23_p2p="$(systemd_exec_arg_service zclassic23 port || true)"
    c23_rpc="$(systemd_exec_arg_service zclassic23 rpcport || true)"
    c23_dd="$(systemd_exec_arg_service zclassic23 datadir || true)"
    c23_snapshot="$(systemd_exec_arg_service zclassic23 load-snapshot-at-own-height || true)"
    [ -n "$c23_rpc" ] || c23_rpc="$expected_c23_rpc"

    zd_state="$(systemd_show_value zclassicd ActiveState || true)"
    zd_sub="$(systemd_show_value zclassicd SubState || true)"
    zd_pid="$(systemd_show_value zclassicd MainPID || true)"
    zd_restarts="$(systemd_show_value zclassicd NRestarts || true)"
    zd_p2p="$(systemd_exec_arg_service zclassicd port || true)"
    zd_rpc="${LEGACY_RPCPORT:-${LEGACY_RPC_PORT:-$(legacy_conf_value rpcport)}}"
    zd_rpc="${zd_rpc:-$expected_zd_rpc}"
    zd_dd="$(systemd_exec_arg_service zclassicd datadir || true)"

    c23_net="$(rpc getnetworkinfo 2>/dev/null || true)"
    c23_chain="$(rpc getblockchaininfo 2>/dev/null || true)"
    c23_rf="$(rpc dumpstate reducer_frontier 2>/dev/null || true)"
    mirror="$(mirror_status_json)"
    zd_net="$(legacy_rpc getnetworkinfo || true)"
    zd_chain="$(legacy_rpc getblockchaininfo || true)"

    c23_height="$(json_field "$mirror" zclassic23_height)"
    [ -n "$c23_height" ] || c23_height="$(json_field "$c23_chain" blocks)"
    c23_headers="$(json_field "$mirror" best_header_height)"
    [ -n "$c23_headers" ] || c23_headers="$(json_field "$c23_chain" headers)"
    c23_hash="$(json_field "$mirror" zclassic23_hash)"
    [ -n "$c23_hash" ] || c23_hash="$(json_field "$c23_chain" bestblockhash)"
    c23_subver="$(json_field "$c23_net" advertised_subver)"
    c23_conns="$(json_field "$c23_net" connections)"
    c23_in="$(json_field "$c23_net" inbound_connections)"
    c23_out="$(json_field "$c23_net" outbound_connections)"
    c23_hs="$(json_field "$c23_net" handshaked_connections)"
    c23_legacy="$(json_field "$c23_net" legacy_compatible_peers)"
    [ -n "$c23_legacy" ] || c23_legacy="$(json_field "$c23_net" magicbean_peers)"
    c23_z23="$(json_field "$c23_net" zclassic23_peers)"
    c23_listening="$(json_field "$c23_net" listening)"
    c23_addr_port="$(json_field "$c23_net" port)"
    hstar="$(json_field "$c23_rf" hstar)"
    coins_applied="$(json_field "$c23_rf" coins_applied_height)"
    blocker="$(json_field "$c23_rf" first_hstar_blocker_reason)"

    zd_height="$(json_field "$mirror" zclassicd_height)"
    [ -n "$zd_height" ] || zd_height="$(json_field "$zd_chain" blocks)"
    zd_headers="$(json_field "$mirror" legacy_headers)"
    [ -n "$zd_headers" ] || zd_headers="$(json_field "$zd_chain" headers)"
    zd_hash="$(json_field "$mirror" zclassicd_hash)"
    [ -n "$zd_hash" ] || zd_hash="$(json_field "$zd_chain" bestblockhash)"
    zd_conns="$(json_field "$zd_net" connections)"
    zd_addr_port="$(json_field "$zd_net" port)"

    lag="$(json_field "$mirror" lag)"
    lag_known="$(json_field "$mirror" lag_known)"
    mirror_running="$(json_field "$mirror" mirror_running)"
    reachable="$(json_field "$mirror" reachable)"
    authority="$(json_field "$mirror" consensus_authority)"
    overrides="$(json_field "$mirror" overrides_total)"

    issues=""
    issue_count=0
    add_issue() {
        local escaped
        escaped="$(json_escape "$1")"
        if [ "$issue_count" -gt 0 ]; then
            issues="${issues},"
        fi
        issues="${issues}\"${escaped}\""
        issue_count=$((issue_count + 1))
    }

    [ "$c23_state" = "active" ] || add_issue "zclassic23 service is not active"
    [ "$c23_sub" = "running" ] || add_issue "zclassic23 service is not running"
    [ "$zd_state" = "active" ] || add_issue "zclassicd service is not active"
    [ "$zd_sub" = "running" ] || add_issue "zclassicd service is not running"
    [ "$c23_p2p" = "$expected_c23_p2p" ] || add_issue "zclassic23 P2P port drift"
    [ "$zd_p2p" = "$expected_zd_p2p" ] || add_issue "zclassicd P2P port drift"
    [ "$c23_rpc" = "$expected_c23_rpc" ] || add_issue "zclassic23 RPC port drift"
    [ "$zd_rpc" = "$expected_zd_rpc" ] || add_issue "zclassicd RPC port drift"
    [ "$c23_subver" = "/ZClassic23:0.1.0/" ] || add_issue "zclassic23 clean user-agent missing"
    [ "$c23_listening" = "true" ] || add_issue "zclassic23 is not listening"
    [ "${c23_hs:-0}" -gt 0 ] 2>/dev/null || add_issue "zclassic23 has no handshaked peers"
    [ "${zd_conns:-0}" -gt 0 ] 2>/dev/null || add_issue "zclassicd has no peers"
    [ "$reachable" = "true" ] || add_issue "mirror RPC path is not reachable"
    [ "$mirror_running" = "true" ] || add_issue "mirror monitor is not running"
    [ "$lag_known" = "true" ] || add_issue "mirror lag is unknown"
    [ "${lag:-999999}" -le 1 ] 2>/dev/null || add_issue "zclassic23 is lagging zclassicd"
    [ "$authority" = "local_consensus_validation" ] || add_issue "consensus authority drift"
    [ "${overrides:-0}" = "0" ] || add_issue "mirror override was used"

    ok=false
    [ "$issue_count" -eq 0 ] && ok=true

    printf '{'
    printf '"schema":"zcl.operator_topology.v1",'
    printf '"ok":%s,"issue_count":%s,"issues":[%s],' "$ok" "$issue_count" "$issues"
    printf '"expected":{"zclassic23_p2p":%s,"zclassic23_rpc":%s,"zclassicd_p2p":%s,"zclassicd_rpc":%s},' \
        "$expected_c23_p2p" "$expected_c23_rpc" "$expected_zd_p2p" "$expected_zd_rpc"
    printf '"zclassic23":{"service_active":"%s","service_substate":"%s","pid":%s,"restarts":%s,' \
        "$(json_escape "$c23_state")" "$(json_escape "$c23_sub")" "${c23_pid:-0}" "${c23_restarts:-0}"
    printf '"datadir":"%s","p2p_port":%s,"rpc_port":%s,"snapshot":"%s",' \
        "$(json_escape "$c23_dd")" "${c23_p2p:-0}" "${c23_rpc:-0}" "$(json_escape "$c23_snapshot")"
    printf '"advertised_subver":"%s","height":%s,"headers":%s,"bestblockhash":"%s",' \
        "$(json_escape "$c23_subver")" "${c23_height:-0}" "${c23_headers:-0}" "$(json_escape "$c23_hash")"
    printf '"hstar":%s,"coins_applied_height":%s,"hstar_blocker":"%s",' \
        "${hstar:-0}" "${coins_applied:-0}" "$(json_escape "$blocker")"
    printf '"connections":%s,"inbound":%s,"outbound":%s,"handshaked":%s,' \
        "${c23_conns:-0}" "${c23_in:-0}" "${c23_out:-0}" "${c23_hs:-0}"
    printf '"legacy_compatible_peers":%s,"zclassic23_peers":%s,"listening":%s,"advertised_p2p_port":%s},' \
        "${c23_legacy:-0}" "${c23_z23:-0}" "${c23_listening:-false}" "${c23_addr_port:-0}"
    printf '"zclassicd":{"service_active":"%s","service_substate":"%s","pid":%s,"restarts":%s,' \
        "$(json_escape "$zd_state")" "$(json_escape "$zd_sub")" "${zd_pid:-0}" "${zd_restarts:-0}"
    printf '"datadir":"%s","p2p_port":%s,"rpc_port":%s,"height":%s,"headers":%s,' \
        "$(json_escape "$zd_dd")" "${zd_p2p:-0}" "${zd_rpc:-0}" "${zd_height:-0}" "${zd_headers:-0}"
    printf '"bestblockhash":"%s","connections":%s,"advertised_p2p_port":%s},' \
        "$(json_escape "$zd_hash")" "${zd_conns:-0}" "${zd_addr_port:-0}"
    printf '"mirror":{"running":%s,"reachable":%s,"lag_known":%s,"lag":%s,"consensus_authority":"%s","overrides_total":%s}' \
        "${mirror_running:-false}" "${reachable:-false}" "${lag_known:-false}" "${lag:-0}" "$(json_escape "$authority")" "${overrides:-0}"
    printf '}\n'
}

topology_status_text() {
    local json
    json="$(topology_status_json)"
    printf 'ok=%s issues=%s c23=%s/%s@%s peers=%s hs=%s subver=%s zclassicd=%s/%s@%s peers=%s mirror_lag=%s authority=%s\n' \
        "$(json_field "$json" ok)" \
        "$(json_field "$json" issue_count)" \
        "$(printf '%s\n' "$json" | sed -n 's/.*"zclassic23":{[^}]*"service_active":"\([^"]*\)".*/\1/p')" \
        "$(printf '%s\n' "$json" | sed -n 's/.*"zclassic23":{[^}]*"service_substate":"\([^"]*\)".*/\1/p')" \
        "$(printf '%s\n' "$json" | sed -n 's/.*"zclassic23":{[^}]*"height":\([0-9][0-9]*\).*/\1/p')" \
        "$(printf '%s\n' "$json" | sed -n 's/.*"zclassic23":{[^}]*"connections":\([0-9][0-9]*\).*/\1/p')" \
        "$(printf '%s\n' "$json" | sed -n 's/.*"zclassic23":{[^}]*"handshaked":\([0-9][0-9]*\).*/\1/p')" \
        "$(printf '%s\n' "$json" | sed -n 's/.*"zclassic23":{[^}]*"advertised_subver":"\([^"]*\)".*/\1/p')" \
        "$(printf '%s\n' "$json" | sed -n 's/.*"zclassicd":{[^}]*"service_active":"\([^"]*\)".*/\1/p')" \
        "$(printf '%s\n' "$json" | sed -n 's/.*"zclassicd":{[^}]*"service_substate":"\([^"]*\)".*/\1/p')" \
        "$(printf '%s\n' "$json" | sed -n 's/.*"zclassicd":{[^}]*"height":\([0-9][0-9]*\).*/\1/p')" \
        "$(printf '%s\n' "$json" | sed -n 's/.*"zclassicd":{[^}]*"connections":\([0-9][0-9]*\).*/\1/p')" \
        "$(json_field "$json" lag)" \
        "$(json_field "$json" consensus_authority)"
    if [ "$(json_field "$json" ok)" != "true" ]; then
        printf '%s\n' "$json"
    fi
}

case "${1:-agent}" in

# ── SIMPLE: agent/operator first check ───────────────────────────
agent|summary|operator|ok|doctor)
    agent_summary_json
    ;;

# ── READ: Chain ──────────────────────────────────────────────────
blocks|height|tip)
    rpc getblockcount
    ;;

block)
    if [ -z "$3" ]; then
        rpc chainview "$2" 1
    else
        rpc chainview "$2" "$3"
    fi
    ;;

chain|stats)
    rpc chainstats ${2:+"$2"} ${3:+"$3"}
    ;;

# ── READ: Transactions ──────────────────────────────────────────
tx)
    rpc gettxdetail "$2"
    ;;

mempool)
    rpc getmempoolinfo
    ;;

# ── READ: Wallet ────────────────────────────────────────────────
balance|bal)
    rpc z_gettotalbalance 0
    ;;

utxos)
    rpc listunspent ${2:-0}
    ;;

notes)
    rpc z_listunspent
    ;;

addrs)
    rpc listunspent 0
    ;;

zaddrs)
    rpc z_listaddresses
    ;;

# ── READ: Network ───────────────────────────────────────────────
peers)
    rpc getpeerinfo
    ;;

network|net)
    rpc getnetworkinfo
    ;;

status|health)
    rpc healthcheck
    ;;

advance|chain-advance)
    rpc dumpstate chain_advance_coordinator
    ;;

peerlife|peer-lifecycle)
    rpc dumpstate peer_lifecycle
    ;;

topology|availability|uptime)
    if [ "${2:-}" = "--json" ] || [ "${2:-}" = "-j" ]; then
        topology_status_json
    else
        topology_status_text
    fi
    ;;

state|dumpstate)
    rpc dumpstate "$2" ${3:+"$3"}
    ;;

log|nodelog|node-log)
    rpc getnodelog "$2" ${3:+"$3"} ${4:+"$4"} ${5:+"$5"}
    ;;

sql|dbquery)
    rpc dbquery "$2" ${3:+"$3"}
    ;;

mirror)
    JSON="$(mirror_status_json)"
    if [ "${2:-}" = "--json" ] || [ "${2:-}" = "-j" ]; then
        printf '%s\n' "$JSON"
    else
        lag_display="$(json_field "$JSON" lag)"
        if [ "$(json_field "$JSON" lag_known)" = "false" ]; then
            lag_display=unknown
        fi
        candidate_lag_display="$(json_field "$JSON" candidate_lag)"
        if [ "$(json_field "$JSON" candidate_lag_known)" = "false" ]; then
            candidate_lag_display=unknown
        fi
        printf 'zclassic23=%s zclassicd=%s lag=%s reachable=%s mirror_running=%s\n' \
            "$(json_field "$JSON" zclassic23_height)" \
            "$(json_field "$JSON" zclassicd_height)" \
            "$lag_display" \
            "$(json_field "$JSON" reachable)" \
            "$(json_field "$JSON" mirror_running)"
        printf 'authority=%s trust=%s candidate_source=%s candidate_lag=%s candidate_lag_known=%s overrides=%s unsafe_overrides=%s blockers=%s last_override_height=%s last_override_safe=%s activation_blocker=%s\n' \
            "$(json_field "$JSON" consensus_authority)" \
            "$(json_field "$JSON" candidate_trust)" \
            "$(json_field "$JSON" candidate_source)" \
            "$candidate_lag_display" \
            "$(json_field "$JSON" candidate_lag_known)" \
            "$(json_field "$JSON" overrides_total)" \
            "$(json_field "$JSON" unsafe_overrides_total)" \
            "$(json_field "$JSON" blockers_total)" \
            "$(json_field "$JSON" last_override_height)" \
            "$(json_field "$JSON" last_override_safe)" \
            "$(json_field "$JSON" activation_blocker)"
        active_error_detail="$(json_field "$JSON" active_error_detail)"
        if [ -n "$active_error_detail" ]; then
            printf 'active_error_detail=%s\n' "$active_error_detail"
        fi
        if [ "$(json_field "$JSON" local_recovery_active)" = "true" ]; then
            legacy_gate="$(json_field "$JSON" legacy_advisory_gated_by_native_retries)"
            [ -n "$legacy_gate" ] || legacy_gate="$(json_field "$JSON" mirror_repair_gated_by_local_retries)"
            printf 'local_recovery missing_height=%s retries=%s peers=%s rotations=%s legacy_advisory_gated=%s\n' \
                "$(json_field "$JSON" local_missing_height)" \
                "$(json_field "$JSON" local_retry_count)" \
                "$(json_field "$JSON" local_distinct_peer_count)" \
                "$(json_field "$JSON" local_peer_rotation_count)" \
                "$legacy_gate"
        fi
        blocker="$(json_field "$JSON" last_blocker_code)"
        if [ -n "$blocker" ]; then
            printf 'last_blocker_code=%s stuck_height=%s stuck_flags=%s stuck_reason=%s stalls=%s\n' \
                "$blocker" \
                "$(json_field "$JSON" stuck_height)" \
                "$(json_field "$JSON" stuck_status_flags)" \
                "$(json_field "$JSON" stuck_reason)" \
                "$(json_field "$JSON" stalls_total)"
            printf 'authority_rewind_target=%s csr_sqlite_rc=%s csr_failure_reason=%s\n' \
                "$(json_field "$JSON" authority_rewind_target)" \
                "$(json_field "$JSON" csr_sqlite_rc)" \
                "$(json_field "$JSON" csr_failure_reason)"
        fi
    fi
    ;;

info)
    rpc getinfo
    ;;

# ── READ: Sapling ───────────────────────────────────────────────
tree)
    rpc saplingtreeinfo
    ;;

scan)
    rpc scancommitments "$2" "$3"
    ;;

verify)
    rpc verifychainroots "$2" "$3"
    ;;

hodl)
    CHARTBIN="$(dirname "$0")/../hodl_chart"
    [ -x "$CHARTBIN" ] || { echo "Run: make hodl_chart" >&2; exit 1; }
    "$CHARTBIN"
    ;;

# ── SEND: Transactions ──────────────────────────────────────────
send)
    rpc sendtoaddress "$2" "$3"
    ;;

zsend)
    # zsend <from_zaddr> <to_zaddr> <amount>
    rpc z_sendmany "$2" "[{\"address\":\"$3\",\"amount\":$4}]"
    ;;

shield)
    # shield <from_taddr> <to_zaddr> <amount>
    rpc z_sendmany "$2" "[{\"address\":\"$3\",\"amount\":$4}]" 0
    ;;

unshield)
    # unshield <from_zaddr> <to_taddr> <amount>
    rpc z_sendmany "$2" "[{\"address\":\"$3\",\"amount\":$4}]"
    ;;

# ── CREATE: Addresses ───────────────────────────────────────────
newaddr)
    rpc getnewaddress
    ;;

newzaddr)
    rpc z_getnewaddress
    ;;

multisig)
    # multisig <nrequired> <key1> <key2> ...
    N="$2"; shift 2
    KEYS=$(printf '"%s",' "$@" | sed 's/,$//')
    rpc createmultisig "$N" "[$KEYS]"
    ;;

# ── RAW RPC ─────────────────────────────────────────────────────
rpc)
    shift
    rpc "$@"
    ;;

# ── HELP ─────────────────────────────────────────────────────────
help|--help|-h)
    cat <<'HELP'
z — deprecated compatibility shim for zclassic23 operator terminals

Primary API: use zclassic23 agent*, MCP zcl_agent_*, or REST /api/v1/agent for
new automation. Keep this wrapper compatible; do not add new operator logic here.

SIMPLE:
  z                     Compact agent/operator summary (recommended first call)
  z agent               Same compact summary
  z summary             Same compact summary
  z status              Full healthcheck diagnostics for drill-down

The simple summary is the same public contract as:
  Binary: zclassic23 agent
  REST:   GET /api/v1/agent
  MCP:  zcl_agent
  Docs: GET /api

READ:
  z blocks              Chain height
  z block 100           Block at height 100
  z block 100 5         5 blocks from height 100
  z chain               Full chain statistics
  z tx <txid>           Transaction UTXO detail
  z balance             All balances (transparent + shielded)
  z utxos               Transparent unspent outputs
  z notes               Shielded unspent notes
  z addrs               Transparent addresses with balances
  z zaddrs              Shielded addresses
  z mempool             Mempool status
  z peers               Connected peers
  z network             P2P reachability and handshake summary
  z status              Healthcheck with chain advance diagnostics
  z topology [--json]   Service ports, peer counts, mirror lag, and drift checks
  z advance             Chain advance source scoring and selection blockers
  z peerlife            Peer lifecycle attempts, handshakes, failures by source
  z state <subsystem>   Generic dumpstate diagnostics
  z log <regex>         Server-side node.log regex tail
  z sql 'SELECT ...'    SELECT-only node.db query
  z mirror [--json]     zclassic23/zclassicd mirror status
  z tree                Sapling commitment tree state
  z scan 476969 486969  Scan blocks for commitments
  z info                Node info

SEND:
  z send <taddr> <amt>                  Transparent send
  z zsend <zfrom> <zto> <amt>           Shielded send (z→z)
  z shield <tfrom> <zto> <amt>          Shield funds (t→z)
  z unshield <zfrom> <tto> <amt>        Unshield funds (z→t)

CREATE:
  z newaddr             New transparent address
  z newzaddr            New shielded address
  z multisig 2 pk1 pk2  Create multisig

RAW:
  z rpc <method> [args...]  Direct RPC call
HELP
    ;;

*)
    echo "Unknown: $1 (try: z help)" >&2
    exit 1
    ;;
esac
