#
# Pre-push LOCAL CI gate.
#
# This project runs CI ONLY locally on the maintainer's own server - never
# GitHub Actions (Actions cost money). `make pre-push-ci` is the synchronous
# gate; full-suite, fuzz, and coverage proof work runs through linger timers so
# pushes are blocked by focused regressions, not by background evidence jobs.
#
# Activate:  make install-hooks   (sets core.hooksPath=tools/githooks)
# Fast local edit-loop before commit:  make fast-ci
# The default pre-push is make pre-push-ci: strict focused tests for exactly
# the files being pushed to origin/main.
# Background proof lanes:  make install-quality-linger
# Bypass once:  git push --no-verify     OR     ZCL_SKIP_PREPUSH=1 git push
# Override the command (e.g. a faster subset):  ZCL_PREPUSH_CMD='make lint'
#
# Full `make ci` remains available for release-grade manual runs. The default
# push path keeps long-running full-suite/fuzz/coverage evidence off the
# critical path.
set -euo pipefail

if [ "${ZCL_SKIP_PREPUSH:-0}" = "1" ]; then
    echo "pre-push: ZCL_SKIP_PREPUSH=1 — skipping the local CI gate." >&2
    exit 0
fi

# git feeds '<local ref> <local sha> <remote ref> <remote sha>' lines on stdin.
# If every ref is a deletion (local sha all-zero) there is nothing new to
# verify — allow the push without running CI.
z="0000000000000000000000000000000000000000"
updates="$(mktemp)"
changed_files="$(mktemp)"
trap 'rm -f "$updates" "$changed_files"' EXIT
have_update=0
while read -r _lref lsha rref rsha; do
    [ -n "${lsha:-}" ] || continue
    [ "$lsha" = "$z" ] && continue
    if [ "$rref" != "refs/heads/main" ]; then
        echo "pre-push: only origin main is allowed (got remote ref $rref)." >&2
        exit 1
    fi
    have_update=1
    printf '%s %s\n' "$lsha" "${rsha:-$z}" >> "$updates"
done
if [ "$have_update" = "0" ]; then
    exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

while read -r lsha rsha; do
    [ -n "${lsha:-}" ] || continue
    if [ "$rsha" = "$z" ]; then
        git diff-tree --no-commit-id --name-only -r "$lsha" >> "$changed_files"
    else
        git diff --name-only "$rsha" "$lsha" -- >> "$changed_files"
    fi
done < "$updates"
sort -u "$changed_files" -o "$changed_files"

CMD="${ZCL_PREPUSH_CMD:-make pre-push-ci}"
echo "pre-push: running local CI gate ($CMD) before push to origin…" >&2
echo "pre-push: semantic changed-file count: $(wc -l < "$changed_files" | tr -d ' ')." >&2
echo "pre-push: full-suite/fuzz/coverage lanes run via 'make install-quality-linger'." >&2
echo "pre-push: bypass one push with 'git push --no-verify' if you must." >&2
if ! ZCL_FAST_CHANGED_FILES_FILE="$changed_files" $CMD; then
    echo "" >&2
    echo "pre-push: LOCAL CI FAILED — push BLOCKED." >&2
    echo "pre-push: fix it, or override this one push with 'git push --no-verify'." >&2
    exit 1
fi
echo "pre-push: local CI green — allowing push." >&2
exit 0
