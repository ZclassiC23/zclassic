ZCL_BLOCKER_REMEDY(utxo_recovery.rewind_overshoot,              OWNER)
ZCL_BLOCKER_REMEDY(ops.binary_stale,                            OWNER)
ZCL_BLOCKER_REMEDY(utxo_ladder_mismatch,                        OWNER)
ZCL_BLOCKER_REMEDY(chain.tip_behind_header_chain,               OWNER)
ZCL_BLOCKER_REMEDY(sha3_window_mismatch,                        OWNER)
ZCL_BLOCKER_REMEDY(tip_finalize.uv_cursor_gap,                  OWNER)
ZCL_BLOCKER_REMEDY(tip_finalize.validation_evidence,            OWNER)
ZCL_BLOCKER_REMEDY(tip_finalize.rewind_churn,                   OWNER)
