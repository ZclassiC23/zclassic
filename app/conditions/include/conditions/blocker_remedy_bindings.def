/* ── OWNER, dynamic-id families (cross-cutting supervisory infra + sim/
 * fuzz harnesses — a per-name/height/reason-code blocker id, not a
 * single subsystem's own condition). ────────────────────────────────── */
ZCL_BLOCKER_REMEDY(stage_spin_*,                                OWNER)
ZCL_BLOCKER_REMEDY(*.disk_low,                                  OWNER)
ZCL_BLOCKER_REMEDY(*.below_snapshot_seed,                       OWNER)
ZCL_BLOCKER_REMEDY(stage_stalled_*,                             OWNER)
