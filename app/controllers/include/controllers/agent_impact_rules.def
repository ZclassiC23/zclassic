/* Shared changed-file -> focused-test rules for native agentimpact and
 * tools/agent_fast_ci.sh.
 *
 * Format:
 *   AGENT_IMPACT_RULE("path-pattern|other-pattern", "group other_group")
 *
 * Patterns use shell/fnmatch syntax. Keep groups space-separated. */

AGENT_IMPACT_RULE("Makefile|README.md|.github/CONTRIBUTING.md|src/main.c|tools/*|tools/scripts/*|deploy/*.service|deploy/*.timer|deploy/examples/*.service|deploy/examples/*.timer|docs/AGENT_API.md|docs/BUILD.md|docs/CODEBASE_MAP.md|docs/HOW_THE_NODE_WORKS.md|docs/GETTING_STARTED.md|docs/work/fast-path.md|docs/RUNBOOK.md|lib/test/src/test_make_lint_gates.c", "make_lint_gates")
