/* Shared changed-file -> focused-test rules for native agentimpact and
 * tools/agent_fast_ci.sh.
 *
 * Format:
 *   AGENT_IMPACT_RULE("path-pattern|other-pattern", "group other_group")
 *
 * Patterns use shell/fnmatch syntax. Keep groups space-separated. */

AGENT_IMPACT_RULE("Makefile|README.md|.github/CONTRIBUTING.md|src/main.c|tools/*|tools/scripts/*|deploy/*.service|deploy/*.timer|deploy/examples/*.service|deploy/examples/*.timer|docs/AGENT_API.md|docs/CODEBASE_MAP.md|docs/HOW_THE_NODE_WORKS.md|docs/GETTING_STARTED.md|docs/work/fast-path.md|docs/RUNBOOK.md|lib/test/src/test_make_lint_gates.c", "make_lint_gates")
AGENT_IMPACT_RULE("app/controllers/include/controllers/agent_impact_rules.def", "syncdiag_rpc make_lint_gates")

AGENT_IMPACT_RULE("tools/mcp/*|tools/mcp_server.c|app/controllers/src/*mcp*|lib/test/src/test_mcp_controllers.c", "mcp_controllers")
AGENT_IMPACT_RULE("lib/mcp/*|lib/util/src/mcp_*|lib/test/src/test_mcp_*|app/controllers/src/diagnostics_registry.c", "mcp_controllers rpc")
AGENT_IMPACT_RULE("app/controllers/src/diagnostics_*.c|app/controllers/include/controllers/diagnostics_*.h", "syncdiag_rpc mcp_controllers make_lint_gates rpc")

AGENT_IMPACT_RULE("lib/net/src/peer_lifecycle.c|lib/net/src/msg_version.c|lib/net/src/protocol.c|app/controllers/src/network_controller.c|lib/test/src/test_peer_lifecycle.c", "peer_lifecycle")
