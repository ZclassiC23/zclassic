/* Shared changed-file -> focused-test rules for native agentimpact and
 * tools/agent_fast_ci.sh.
 *
 * Format:
 *   AGENT_IMPACT_RULE("path-pattern|other-pattern", "group other_group")
 *
 * Patterns use shell/fnmatch syntax. Keep groups space-separated. */

AGENT_IMPACT_RULE("Makefile|src/main.c|tools/*|tools/scripts/*|deploy/*.service|deploy/*.timer|deploy/examples/*.service|deploy/examples/*.timer|docs/AGENT_API.md|docs/CODEBASE_MAP.md|docs/HOW_THE_NODE_WORKS.md|docs/work/fast-path.md|docs/RUNBOOK.md|lib/test/src/test_make_lint_gates.c", "make_lint_gates")
AGENT_IMPACT_RULE("app/controllers/include/controllers/agent_impact_rules.def", "syncdiag_rpc make_lint_gates")

AGENT_IMPACT_RULE("tools/mcp/*|tools/mcp_server.c|app/controllers/src/*mcp*|lib/test/src/test_mcp_controllers.c", "mcp_controllers")
AGENT_IMPACT_RULE("lib/mcp/*|lib/util/src/mcp_*|lib/test/src/test_mcp_*|app/controllers/src/diagnostics_registry.c", "mcp_controllers")

AGENT_IMPACT_RULE("lib/net/src/peer_lifecycle.c|lib/net/src/msg_version.c|lib/net/src/protocol.c|app/controllers/src/network_controller.c|lib/test/src/test_peer_lifecycle.c", "peer_lifecycle")
AGENT_IMPACT_RULE("lib/net/src/connman.c", "connman_addnode_fallback net")
AGENT_IMPACT_RULE("lib/net/include/net/msg_internal.h|lib/net/include/net/peer_lifecycle.h|lib/net/include/net/port_policy.h|lib/net/include/net/version.h", "peer_lifecycle")
AGENT_IMPACT_RULE("lib/net/src/msgprocessor.c|lib/net/include/net/msgprocessor.h", "net body_fetch_missing_have_data_condition sync_watchdog_conditions")
AGENT_IMPACT_RULE("lib/net/include/net/protocol.h", "net")
AGENT_IMPACT_RULE("lib/test/src/test_net.c", "net")

AGENT_IMPACT_RULE("app/models/src/peer.c|app/models/include/models/peer.h|lib/test/src/test_models_app.c", "models")
AGENT_IMPACT_RULE("app/controllers/src/network_controller.c|app/controllers/include/controllers/network_controller.h|app/controllers/src/sync_controller.c|lib/test/src/test_syncdiag_rpc.c", "syncdiag_rpc")
AGENT_IMPACT_RULE("domain/consensus/*|lib/consensus/*|lib/chain/*|lib/validation/*|lib/script/*|lib/primitives/*", "consensus_parity chain")

AGENT_IMPACT_RULE("app/jobs/src/tip_finalize_stage*.c|app/jobs/include/jobs/tip_finalize_stage.h|app/jobs/src/reducer_frontier*.c|app/jobs/include/jobs/reducer_frontier.h|lib/test/src/test_tip_finalize_stage.c|lib/test/src/test_reducer_frontier.c", "tip_finalize_stage reducer_frontier make_lint_gates")
AGENT_IMPACT_RULE("app/jobs/src/validate_headers_stage.c|app/jobs/src/validate_headers_validator.c|app/jobs/src/validate_headers_report.c|app/jobs/src/validate_headers_internal.h|app/jobs/include/jobs/validate_headers_stage.h|lib/test/src/test_validate_headers_stage.c", "validate_headers_stage make_lint_gates")
AGENT_IMPACT_RULE("app/conditions/src/stale_validate_headers_repair.c|lib/test/src/test_stale_validate_headers_repair_condition.c", "stale_validate_headers_repair_condition validate_headers_stage make_lint_gates")
AGENT_IMPACT_RULE("app/conditions/src/body_fetch_missing_have_data.c|lib/test/src/test_body_fetch_missing_have_data_condition.c", "body_fetch_missing_have_data_condition sync_watchdog_conditions make_lint_gates")
AGENT_IMPACT_RULE("app/services/src/sync_monitor.c|app/services/include/services/sync_monitor.h|lib/test/src/test_sync_watchdog_conditions.c", "sync_watchdog_conditions body_fetch_missing_have_data_condition make_lint_gates")
AGENT_IMPACT_RULE("app/conditions/src/chain_integrity_failed.c|app/services/include/services/chain_restore_integrity.h|lib/test/src/test_chain_integrity_failed_condition.c|lib/test/src/test_service_state.c", "chain_integrity_failed_condition service_state make_lint_gates")

AGENT_IMPACT_RULE("config/src/boot_services.c", "make_lint_gates syncdiag_rpc")
AGENT_IMPACT_RULE("config/src/boot.c|config/src/boot_index.c|config/src/boot_refold*.c|config/include/config/boot_internal.h|lib/test/src/test_load_verify_boot.c", "boot_refold_window_extend chain_state_repo load_verify_boot make_lint_gates")
AGENT_IMPACT_RULE("config/src/app_context.c|config/include/config/boot.h|lib/test/src/test_app_context.c", "app_context make_lint_gates")

AGENT_IMPACT_RULE("app/services/src/node_health_service.c|app/services/include/services/node_health_service.h|lib/test/src/test_node_health_service.c", "node_health_service syncdiag_rpc api mcp_controllers")
AGENT_IMPACT_RULE("app/controllers/src/api_controller*.c|app/controllers/src/api_controller_internal.h|lib/test/src/test_api.c", "api")
AGENT_IMPACT_RULE("app/controllers/src/blockchain_controller*.c|app/controllers/include/controllers/blockchain_controller.h|lib/test/src/test_rpc_safety.c", "rpc_safety make_lint_gates")
AGENT_IMPACT_RULE("app/controllers/src/agent_controller.c|app/controllers/src/agent_impact_rules.c|app/controllers/src/agent_interface_controller.c|app/controllers/src/agent_runtime_controller.c|app/controllers/src/event_agent_summary.c|app/controllers/src/event_agent_summary.h|app/controllers/include/controllers/agent_controller.h|app/controllers/include/controllers/agent_impact_rules.h|app/controllers/src/event_controller.c", "syncdiag_rpc mcp_controllers api make_lint_gates node_health_service")
