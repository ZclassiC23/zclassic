/* Canonical dumpstate subsystem descriptors.
 *
 * The including translation unit defines the DIAG_* category macros. Keep
 * this file data-only: dispatcher order, statecatalog metadata, MCP advisory
 * parameters, health rollup, and registry tests all consume these rows. */

#ifndef DIAG_ENTRY
#error "define the DIAG_* descriptor macros before including diagnostics_dumpers.def"
#endif

    DIAG_ENTRY("supervisor", supervisor_dump_state_json,
               "root supervisor: registered liveness contracts, ticks_run, stall_fires, deadlines",
               "runtime", "runtime", "lib/util/src/supervisor.c",
               "in_process_snapshot", "cheap",
               "child service name, or use subsystem=supervisor.<name>",
               "sync.watchdog", "net.outbound_floor",
               "lib/test/src/test_supervisor.c", false),
    DIAG_CONDITION("blocker", blocker_dump_state_json,
                   "typed blocker registry: active blockers by class {permanent,transient,dependency,resource}, "
