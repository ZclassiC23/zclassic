/* Canonical dumpstate subsystem descriptors.
 *
 * The including translation unit defines the DIAG_* category macros. Keep
 * this file data-only: dispatcher order, statecatalog metadata, native advisory
 * parameters, health rollup, and registry tests all consume these rows. */

#ifndef DIAG_ENTRY
#error "define the DIAG_* descriptor macros before including diagnostics_dumpers.def"
#endif

    DIAG_ENTRY("supervisor", supervisor_dump_state_json,
               "root supervisor: registered liveness contracts, ticks_run, stall_fires, deadlines",
               "runtime", "runtime", "lib/util/src/supervisor.c",
               "in_process_snapshot", "cheap",
               "child service name, or use subsystem=supervisor.<name>",
               "sync.watchdog", "net.outbound_floor",
               "lib/test/src/test_supervisor.c", false),
    DIAG_RUNTIME("supervisor_backstop", supervisor_backstop_dump_state_json,
                 "independent sweep-heartbeat watcher for the root supervisor "
                 "thread (Pillar 7): freeze threshold, respawn latch, "
                 "off-systemd fallback state",
                 "lib/util/src/supervisor_backstop.c",
                 "lib/test/src/test_supervisor_backstop.c"),
    DIAG_CONDITION("blocker", blocker_dump_state_json,
                   "typed blocker registry: active blockers by class {permanent,transient,dependency,resource}, "
                   "deadlines, escape actions, fire counts",
                   "lib/util/src/blocker.c", DIAG_TEST_DEFAULT),
    DIAG_CONDITION("blocker_history", blocker_history_dump_state_json,
                   "durable blocker/condition firing history over EV_OPERATOR_NEEDED "
                   "pages, bridged into the durable event log and folded incrementally: "
                   "total_events, unparsed_events, overflow_dropped, distinct_ids, "
                   "capacity, and top {id, fire_count, first_seen_unix, last_seen_unix, "
                   "last_reason} sorted by fire_count descending (key = max rows, default 10)",
                   "app/services/src/blocker_history.c",
                   "lib/test/src/test_blocker_history.c"),
    DIAG_CONDITION("watchdog", condition_engine_dump_state_json,
                   "compat alias for condition_engine status",
                   "lib/framework/src/condition.c",
                   "lib/test/src/test_condition_engine.c"),
