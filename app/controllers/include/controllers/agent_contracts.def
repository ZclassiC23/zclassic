/* C-owned first-call agent API registry.
 *
 * Consumer must define:
 *   AGENT_CONTRACT(method, capability, schema, native, mcp, rest,
 *                  api_cli_field, api_mcp_field,
 *                  ops_surface, ops_rank, ops_name, ops_purpose,
 *                  purpose)
 *
 * Keep this as data only. Static CLI dispatch remains explicit because it
 * carries function pointers and parameter behavior; this table owns the
 * repeated method/schema/tool vocabulary used by discovery and probes. */

AGENT_CONTRACT("agent", "runtime_status", "zcl.public_status.v1",
               "zclassic23 agent", "zcl_agent", "GET /api/v1/agent",
               "first_command", "first_tool",
               "direct", 2, "live_status",
               "serving state, heights, peers, blockers, lane, readiness",
               "bounded live status: build, lane safety, heights, peers, blocker, and next action")
AGENT_CONTRACT("status", "runtime_status_alias", "zcl.public_status.v1",
               "zclassic23 status", "zcl_agent", "GET /api/v1/agent",
               "", "",
               "", 0, "", "",
               "native compatibility alias for the bounded live status contract; payload is the agent status JSON")
AGENT_CONTRACT("agentops", "operator_command_center", "zcl.agent_ops.v1",
               "zclassic23 agentops", "zcl_agent_ops", "",
               "ops_command", "ops_tool",
               "direct", 1, "no_jq_contract",
               "compact top-level fields for common agent decisions",
               "compact no-jq command center: API routes, quality summary, and next-work list")
AGENT_CONTRACT("agentdiagnose", "bounded_diagnosis",
