/* C-owned first-call agent API registry.
 *
 * Consumer must define:
 *   AGENT_CONTRACT(method, capability, schema, native, rest, api_cli_field,
 *                  ops_surface, ops_rank, ops_name, ops_purpose, purpose)
 *
 * Keep this as data only. Static CLI dispatch remains explicit because it
 * carries function pointers and parameter behavior; this table owns the
 * repeated method/schema/tool vocabulary used by discovery and probes. */

AGENT_CONTRACT("agent", "full_compatibility_status", "zcl.public_status.v2",
               "zclassic23 agent", "GET /api/v1/agent",
               "first_command",
               "direct", 2, "live_status",
               "full compatibility status: serving state, heights, peers, blockers, lane, readiness",
               "full compatibility status document: build, lane safety, heights, peers, blocker, and next action")
