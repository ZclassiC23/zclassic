/* C-owned first-call agent API registry.
 *
 * Consumer must define:
 *   AGENT_CONTRACT(method, capability, schema, native, mcp, rest, purpose)
 *
 * Keep this as data only. Static CLI dispatch remains explicit because it
 * carries function pointers and parameter behavior; this table owns the
 * repeated method/schema/tool vocabulary used by discovery and probes. */

AGENT_CONTRACT("agent", "runtime_status", "zcl.public_status.v1",
               "zclassic23 agent", "zcl_agent", "GET /api/v1/agent",
               "compact live status, lane safety, blocker, and next action")
AGENT_CONTRACT("agentops", "operator_command_center", "zcl.agent_ops.v1",
               "zclassic23 agentops", "zcl_agent_ops", "",
               "compact no-jq agent command center and next-work list")
AGENT_CONTRACT("agentinterface", "discover_interface",
               "zcl.agent_interface.v1", "zclassic23 agentinterface",
               "zcl_agent_interface", "",
               "ranked transports, payload rules, and C ownership boundaries")
AGENT_CONTRACT("agentcontracts", "contract_registry",
               "zcl.agent_contracts.v1", "zclassic23 agentcontracts",
               "zcl_agent_contracts", "", "contract registry")
AGENT_CONTRACT("agentbuild", "build_loop", "zcl.agent_build.v1",
               "zclassic23 agentbuild", "zcl_agent_build", "",
               "cache-aware compile/test/reproducibility contract")
AGENT_CONTRACT("agentmap", "code_map", "zcl.agent_map.v1",
               "zclassic23 agentmap", "zcl_agent_map", "",
               "AI-coder code/docs/test map")
AGENT_CONTRACT("agentlanes", "lane_topology", "zcl.agent_lanes.v1",
               "zclassic23 agentlanes", "zcl_agent_lanes", "",
               "canonical, soak, and dev lane topology with restart/deploy rules")
AGENT_CONTRACT("agentliveness", "unified_liveness",
               "zcl.agent_liveness.v1", "zclassic23 agentliveness",
               "zcl_agent_liveness", "",
               "one lane, listener, supervisor, and background quality liveness rollup")
AGENT_CONTRACT("agentimpact", "changed_files_to_tests",
               "zcl.agent_impact.v1", "zclassic23 agentimpact <files...>",
               "zcl_agent_impact", "",
               "map edits to risk flags, docs, and focused validation")
AGENT_CONTRACT("agentdeployguard", "deploy_guard",
               "zcl.agent_deploy_guard.v1",
               "zclassic23 agentdeployguard [action]",
               "zcl_agent_deploy_guard", "",
               "machine allow/refuse decision before restart or deploy")
AGENT_CONTRACT("statecatalog", "state_catalog", "zcl.state_catalog.v1",
               "zclassic23 statecatalog", "zcl_state_catalog", "",
               "machine-readable zcl_state subsystem catalog with keys, cost, and owner hints")
AGENT_CONTRACT("timeline", "semantic_timeline", "zcl.timeline.v1",
               "zclassic23 timeline '{\"category\":\"sync\",\"count\":50,\"since_secs\":3600}'",
               "zcl_timeline", "",
               "category-filtered structured event timeline with bounded semantic filters, log refs, summaries, and seq cursors")
AGENT_CONTRACT("getmirrorstatus", "mirror_status", "zcl.mirror_status.v1",
               "zclassic23 getmirrorstatus", "zcl_mirror_status", "",
               "mirror reachability, lag, hash agreement, and active blocker contract")
AGENT_CONTRACT("api", "api_index", "zcl.api_index.v1",
               "zclassic23 api", "zcl_openapi", "GET /api/v1",
               "native and REST API discovery index")
