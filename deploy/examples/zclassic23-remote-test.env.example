# Example environment file for deploy/examples/zclassic23-remote-test-node.service.
#
# Copy to:
#     ~/.config/zclassic23/remote-test.env
#
# Variable contract (systemd expands with $VAR, which splits on
# whitespace, so each flag ends up as its own argv element):
#
#   ZCL_TEST_EXTERNALIP_FLAG - single -externalip=<ip:port> flag, or empty.
#                              Use this when the remote node has a stable
#                              clearnet address for peers to dial back to.
#
#   ZCL_TEST_ADDNODE_FLAGS   - space-separated list of -addnode=<ip[:port]>
#                              flags. Use local legacy/zclassic23 peers plus
#                              several external peers for eclipse resistance.

ZCL_TEST_EXTERNALIP_FLAG=-externalip=205.209.104.118:18033

ZCL_TEST_ADDNODE_FLAGS=-addnode=127.0.0.1:8033 -addnode=140.174.189.17 -addnode=140.174.189.3 -addnode=37.187.76.79 -addnode=162.55.92.62 -addnode=157.90.223.151 -addnode=157.173.195.203 -addnode=85.239.232.93 -addnode=154.38.178.121 -addnode=51.178.179.75
