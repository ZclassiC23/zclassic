# Example environment file for deploy/zclassic23-standby.service.
#
# Copy to ~/.config/zclassic23/standby.env and edit, then:
#   systemctl --user daemon-reload && systemctl --user restart zclassic23-standby
#
# The unit loads this AFTER its baked-in defaults, so anything you set here
# overrides the default. If the file is missing the standby still starts on the
# defaults (its own datadir + ports 8053/18272).
#
# Variable contract:
#
#   STANDBY_DATADIR  — the standby node's data directory. Keep it DISTINCT from
#                      every protected datadir (~/.zclassic-c23 [canonical],
#                      ~/.zclassic [zclassicd], the mint/serve/soak copies).
#                      NOTE: if you change this away from the default
#                      ~/.zclassic-c23-standby you must ALSO add a drop-in
#                      overriding ReadWritePaths / StandardOutput / ZCL_CORE_DIR
#                      (see the comment in the unit — systemd cannot expand $ENV
#                      in those directives).
#
#   STANDBY_PORT     — P2P listen port. Must not collide with canonical (8033),
#                      the zclassicd oracle (8034), soak (8043), or dev.
#
#   STANDBY_RPCPORT  — RPC port. Must not collide with canonical (18232),
#                      soak (18242), dev (18252), or your work node.

STANDBY_DATADIR=/home/rhett/.zclassic-c23-standby
STANDBY_PORT=8053
STANDBY_RPCPORT=18272
