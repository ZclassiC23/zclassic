    ZCL_COMMAND_LATENCY_FOREGROUND, ZCL_COMMAND_COST_MODERATE,
    ZCL_COMMAND_CONFIRM_PLAN_COMMIT,
    ZCL_COMMAND_LANE_LOCAL | ZCL_COMMAND_LANE_ALL_NODE,
    ZCL_COMMAND_CAP_WALLET_REQUEST, ZCL_COMMAND_TRAIT_NONE,
    "ZSWP write plan/commit handshake is a follow-up native wave; the "
    "swap_participate RPC remains available at the node RPC layer")
