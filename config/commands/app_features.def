/* ZCL built-in application features, mounted under the `app` root (the frozen
 * root set stays at seven: status/core/app/dev/ops/discover/code). These are the
 * native-command twin of tools/mcp/controllers/app_controller.c: names (ZNAM),
 * ZSLP tokens, messaging (ZMSG), the file market, and cross-chain atomic swaps.
 *
 * Read leaves are READY and dispatch MCP-free through zcl_native_bridge_command
 * (body functions in app/controllers/src/app_native_handlers.c, bound in
 * tools/command/native_command.c's g_bridge_tools[]/g_bridge_native_body[]).
 * The destructive app-layer commands are PLANNED (fail-closed, exit 3) until the
 * app-write plan/commit handshake lands — the same posture core.def gives
 * wallet spends. Their backing RPC methods stay available at the node RPC layer,
 * so no capability is lost by keeping them PLANNED here. Consumer defines
 * ZCL_COMMAND_*. */

/* Branch summaries are deliberately terse single words: they render inside the
 * parent `app` branch menu, which is bounded by ZCL_COMMAND_BRANCH_BUDGET and
 * already carries six longer-summary children (auth/account/list/inspect/
 * protocols/invoke). Keeping these short keeps the `app` menu well under
 * budget (verified in test_native_api_contract's per-branch menu sweep). */
ZCL_COMMAND_BRANCH("app.names", "app", "Names", ZCL_COMMAND_LAYER_APP)
ZCL_COMMAND_BRANCH("app.tokens", "app", "Tokens", ZCL_COMMAND_LAYER_APP)
ZCL_COMMAND_BRANCH("app.messaging", "app", "Messaging", ZCL_COMMAND_LAYER_APP)
ZCL_COMMAND_BRANCH("app.market", "app", "Market", ZCL_COMMAND_LAYER_APP)
ZCL_COMMAND_BRANCH("app.swap", "app", "Swaps", ZCL_COMMAND_LAYER_APP)

/* ── Names (ZNAM) ──────────────────────────────────────────────────── */

ZCL_COMMAND_READY_READ(
    "app.names.resolve", "app.names", "", "Resolve a ZCL Name to its target",
    "One ZCL Name's resolved target (.onion, z-address, or t-address) looked up "
    "live on-chain at call time; absent/error if the name is not registered.", 0,
    "names,znam,resolve", "zcl.app_name_resolve.input.v1",
    "zcl.app_name_record.v1", "name", "name",
    "zclassic23 app names resolve alice",
    ZCL_COMMAND_LAYER_APP, ZCL_COMMAND_SCOPE_NODE, ZCL_COMMAND_AUTH_PUBLIC,
    ZCL_COMMAND_LATENCY_FAST, ZCL_COMMAND_COST_LOW,
    ZCL_COMMAND_LANE_LOCAL | ZCL_COMMAND_LANE_ALL_NODE, ZCL_COMMAND_CAP_ZNAM,
    ZCL_COMMAND_TRAIT_IDEMPOTENT,
    ZCL_COMMAND_TRANSPORT_NATIVE, zcl_native_bridge_command)

