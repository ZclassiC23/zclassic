    "zcl.app_name_txresult.v1", "name,type,value", "name",
    "zclassic23 app names register --input='{\"name\":\"alice\",\"type\":\"zaddr\",\"value\":\"zs1..\"}'",
    ZCL_COMMAND_LAYER_APP, ZCL_COMMAND_EFFECT_MUTATE, ZCL_COMMAND_RISK_APP_WRITE,
    ZCL_COMMAND_SCOPE_NODE, ZCL_COMMAND_AUTH_OWNER, ZCL_COMMAND_MODE_SYNC,
