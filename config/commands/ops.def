/* Operator rollup dashboards live under ops.debug (not new top-level ops.*
 * children) for the same reason ops.debug.explain/profile do: the top-level
 * ops menu is within ~70 bytes of ZCL_COMMAND_BRANCH_BUDGET (proven by
 * test_branch_menus_shallow), so a new top-level branch would overflow it.
 * Each leaf carries short bare-root aliases (kpi, milestone, selfheal) so the
 * deep canonical path barely shows in practice. */
ZCL_COMMAND_BRANCH("ops.debug.dash", "ops.debug", "Operator rollup dashboards",
                   ZCL_COMMAND_LAYER_OPS)

