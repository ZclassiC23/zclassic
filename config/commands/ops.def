/* Bounded diagnosis and node operations (contract §4).
 *
 * Same rule as core.def: a READ-ONLY leaf with a genuine live handler binds
 * zcl_native_bridge_command; jobs, recovery mutations, and reads without a
 * bridged handler are PLANNED (fail-closed, exit 3). */

ZCL_COMMAND_READY_READ(
    "ops.health", "ops", "", "Health rollup",
    "Every registered health check with its pass/fail and the overall serving "
    "verdict, read live from the running node at call time.", 0,
    "health,checks,status,rollup", "zcl.command.empty_input.v1",
    "zcl.health.v1", "", "", "zclassic23 ops health",
    ZCL_COMMAND_LAYER_OPS, ZCL_COMMAND_SCOPE_NODE, ZCL_COMMAND_AUTH_PUBLIC,
    ZCL_COMMAND_LATENCY_FAST, ZCL_COMMAND_COST_LOW,
    ZCL_COMMAND_LANE_LOCAL | ZCL_COMMAND_LANE_ALL_NODE,
    ZCL_COMMAND_CAP_CHAIN_READ, ZCL_COMMAND_TRAIT_IDEMPOTENT,
    ZCL_COMMAND_TRANSPORT_NATIVE, zcl_native_bridge_command)

