/* Operator-UX diagnostics live under the existing ops.debug branch — a new
 * top-level ops.* branch would push the ops menu over its 1600-byte budget
 * (ZCL_COMMAND_BRANCH_BUDGET; proven by test_branch_menus_shallow). The
 * bare-root aliases (`zclassic23 explain sync`, `zclassic23 profile`) are
 * the primary invocation surface, so the canonical path barely shows. */
ZCL_COMMAND_BRANCH("ops.debug", "ops", "Diagnostics",
                   ZCL_COMMAND_LAYER_OPS)
ZCL_COMMAND_READY_READ(
    "ops.debug.explain", "ops.debug", "explain,ops.explain",
    "Explain a subsystem in plain prose",
    "A plain-prose explanation of one subsystem (sync, blockers, health, …) "
    "generated from live node state at call time; narrative, not a stable "
    "machine schema.", 0,
    "explain,sync,blockers,health,why,diagnose,prose",
    "zcl.ops_explain.input.v1", "zcl.ops_explain.v1", "topic", "topic",
    "zclassic23 explain sync",
    ZCL_COMMAND_LAYER_OPS, ZCL_COMMAND_SCOPE_NODE, ZCL_COMMAND_AUTH_OPERATOR,
    ZCL_COMMAND_LATENCY_FAST, ZCL_COMMAND_COST_LOW,
    ZCL_COMMAND_LANE_LOCAL | ZCL_COMMAND_LANE_ALL_NODE,
    ZCL_COMMAND_CAP_CHAIN_READ, ZCL_COMMAND_TRAIT_IDEMPOTENT,
    ZCL_COMMAND_TRANSPORT_NATIVE, zcl_native_handle_ops_explain)

ZCL_COMMAND_READY_READ(
    "ops.debug.profile", "ops.debug", "profile,ops.profile",
    "Sample thread CPU + stage rates",
    "Per-thread CPU and wait-channel samples plus stage advance rates gathered "
    "over `seconds` of live sampling; a wall-clock snapshot of that window, not "
    "cumulative.", ZCL_COMMAND_LIST_BUDGET,
    "profile,cpu,threads,bottleneck,perf,wchan,sample",
    "zcl.ops_profile.input.v1", "zcl.ops_profile.v1", "seconds,top_n",
    "seconds", "zclassic23 profile 3",
    ZCL_COMMAND_LAYER_OPS, ZCL_COMMAND_SCOPE_NODE, ZCL_COMMAND_AUTH_OPERATOR,
    ZCL_COMMAND_LATENCY_FOREGROUND, ZCL_COMMAND_COST_MODERATE,
    ZCL_COMMAND_LANE_LOCAL | ZCL_COMMAND_LANE_ALL_NODE,
    ZCL_COMMAND_CAP_CHAIN_READ, ZCL_COMMAND_TRAIT_IDEMPOTENT,
    ZCL_COMMAND_TRANSPORT_NATIVE, zcl_native_handle_ops_profile)

ZCL_COMMAND_READY_READ(
    "ops.debug.producer", "ops.debug", "ops.producer.status",
    "Read a producer datadir's fold progress + receipt",
    "One producer datadir's fold cursor, receipt, and anchor ETA read from "
    "progress.kv (not process memory or human logs); reflects successful "
    "durable apply samples and names the compiled anchor as its target.", 0,
    "producer,mint,anchor,receipt,fold,progress,eta",
    "zcl.ops_producer_status.input.v1", "zcl.ops_producer_status.v1",
    "datadir", "datadir",
    "zclassic23 ops producer status --datadir=/home/you/.zclassic-c23-mint",
    ZCL_COMMAND_LAYER_OPS, ZCL_COMMAND_SCOPE_LOCAL, ZCL_COMMAND_AUTH_OPERATOR,
    ZCL_COMMAND_LATENCY_FAST, ZCL_COMMAND_COST_LOW,
    ZCL_COMMAND_LANE_LOCAL | ZCL_COMMAND_LANE_ALL_NODE,
    ZCL_COMMAND_CAP_CHAIN_READ, ZCL_COMMAND_TRAIT_IDEMPOTENT,
    ZCL_COMMAND_TRANSPORT_NATIVE, zcl_native_handle_ops_producer_status)

ZCL_COMMAND_READY_READ(
    "ops.debug.rom", "ops.debug", "ops.rom", "ROM compilation fold progress",
    "Live ROM-compile-fold telemetry (dumpstate rom_compile) read from THIS "
    "running node at call time — height/target/percent/rate/ETA, the eight "
    "reducer stages' step_us_ewma, the ROM pipeline rows (fold -> seal -> "
    "manifest -> bundle export), and the layer ladder; when no fold is "
    "active this is the steady-state ladder, not an error. CLI-only argv "
    "inputs (intercepted before dispatch, not part of the machine JSON "
    "contract): --watch redraws in place until interrupted, --once renders a "
    "single frame, --interval=<secs> sets the poll cadence (clamped 1..60s), "
    "and --datadir=<dir> renders a FOREIGN offline producer datadir read-only "
    "(progress.kv + segments + mint-progress.log) instead of this node.",
    ZCL_COMMAND_LIST_BUDGET,
    "rom,compile,fold,progress,checkpoint,anchor,layers,ascii,mint",
    "zcl.command.empty_input.v1", "zcl.rom_compile.v1", "", "",
    "zclassic23 ops rom",
    ZCL_COMMAND_LAYER_OPS, ZCL_COMMAND_SCOPE_NODE, ZCL_COMMAND_AUTH_OPERATOR,
    ZCL_COMMAND_LATENCY_FAST, ZCL_COMMAND_COST_LOW,
    ZCL_COMMAND_LANE_LOCAL | ZCL_COMMAND_LANE_ALL_NODE,
    ZCL_COMMAND_CAP_CHAIN_READ, ZCL_COMMAND_TRAIT_IDEMPOTENT,
    ZCL_COMMAND_TRANSPORT_NATIVE, zcl_native_handle_ops_rom)

