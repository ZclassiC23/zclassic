    "datadir", "datadir",
    "zclassic23 ops producer status --datadir=/home/you/.zclassic-c23-mint",
    ZCL_COMMAND_LAYER_OPS, ZCL_COMMAND_SCOPE_LOCAL, ZCL_COMMAND_AUTH_OPERATOR,
    ZCL_COMMAND_LATENCY_FAST, ZCL_COMMAND_COST_LOW,
