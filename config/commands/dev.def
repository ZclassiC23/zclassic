ZCL_COMMAND_BRANCH("dev.change", "dev", "Classify and apply changes",
                   ZCL_COMMAND_LAYER_DEV)
ZCL_COMMAND_BRANCH("dev.loop", "dev", "Persistent save-to-verdict loop",
