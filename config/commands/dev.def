/* Checkout-local development commands. Never bind these to RPC/REST/MCP. */

ZCL_COMMAND_READY_READ(
    "dev.status", "dev", "", "Read the latest bounded native cycle verdict",
    "dev,status,cycle,verdict", "zcl.command.empty_input.v1",
    "zcl.dev_status.v1", "", "", "zclassic23 dev status",
    ZCL_COMMAND_LAYER_DEV, ZCL_COMMAND_SCOPE_LOCAL,
    ZCL_COMMAND_AUTH_OPERATOR, ZCL_COMMAND_LATENCY_INSTANT,
    ZCL_COMMAND_COST_LOW, ZCL_COMMAND_LANE_LOCAL,
    ZCL_COMMAND_CAP_DEV_STATE_READ,
    ZCL_COMMAND_TRAIT_IDEMPOTENT | ZCL_COMMAND_TRAIT_DEV_ONLY,
    ZCL_COMMAND_TRANSPORT_NATIVE, zcl_native_handle_dev_status)

ZCL_COMMAND_BRANCH("dev.core", "dev", "Core boundary and guarded proof lanes",
                   ZCL_COMMAND_LAYER_DEV)
ZCL_COMMAND_BRANCH("dev.app", "dev", "Build capability-scoped C Apps",
                   ZCL_COMMAND_LAYER_DEV)
ZCL_COMMAND_BRANCH("dev.change", "dev", "Classify and apply source changes",
                   ZCL_COMMAND_LAYER_DEV)
ZCL_COMMAND_BRANCH("dev.loop", "dev", "Persistent save-to-verdict state machine",
                   ZCL_COMMAND_LAYER_DEV)
ZCL_COMMAND_BRANCH("dev.test", "dev", "Focused deterministic proof selection",
                   ZCL_COMMAND_LAYER_DEV)
ZCL_COMMAND_BRANCH("dev.generation", "dev", "Immutable generation provenance",
                   ZCL_COMMAND_LAYER_DEV)
ZCL_COMMAND_BRANCH("dev.diagnose", "dev", "Bounded failure capsule lookup",
                   ZCL_COMMAND_LAYER_DEV)

