ZCL_COMMAND_BRANCH("dev.hotswap", "dev",
                   "Tier-1 command-leaf hot-swap",
                   ZCL_COMMAND_LAYER_DEV)

ZCL_COMMAND_DEV_COMMAND(
    "dev.hotswap.apply", "dev.hotswap", "", "Live module hot-swap: forwards to "
    "the resident dev node; verify-only unless -hotswap-activate + "
    "ZCL_HOTSWAP_ACTIVATE=1 on the dev datadir (canonical refused)",
    "The activation report (ok, verify_only, activated, generation, "
    "artifact hash) from the RESIDENT dev node's live registry, not this "
    "CLI process; a real swap needs both activation flags set.", 0,
    "hotswap,apply,leaves,generation,relink", "zcl.dev_hotswap_input.v1",
    "zcl.dev_hotswap.v1", "so_path,probe_leaf", "so_path",
    "zclassic23-dev dev hotswap apply --input='{\"so_path\":\"/tmp/gen.so\","
    "\"probe_leaf\":\"core.status\"}'",
    ZCL_COMMAND_EFFECT_MUTATE,
    ZCL_COMMAND_RISK_DEV_MUTATION, ZCL_COMMAND_SCOPE_DEV_LANE,
    ZCL_COMMAND_AUTH_OWNER, ZCL_COMMAND_MODE_SYNC,
    ZCL_COMMAND_LATENCY_FAST, ZCL_COMMAND_COST_MODERATE,
    ZCL_COMMAND_CONFIRM_NONE, ZCL_COMMAND_LANE_DEV,
    ZCL_COMMAND_CAP_HOTSWAP | ZCL_COMMAND_CAP_DEV_ACTIVATE,
    ZCL_COMMAND_TRAIT_DEV_ONLY, zcl_native_handle_dev_hotswap_apply,
