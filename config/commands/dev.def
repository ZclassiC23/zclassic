/* Checkout-local development commands. Native transport only. */

ZCL_COMMAND_READY_READ(
    "dev.status", "dev", "", "Read the latest native cycle verdict",
    "The most recent native compile/test/lint cycle verdict persisted by "
    "the local dev-state store at call time; reports status=unavailable "
    "if no cycle has run yet.", 0,
    "dev,status,cycle,verdict", "zcl.command.empty_input.v1",
    "zcl.dev_cycle.v1", "", "", "zclassic23 dev status",
    ZCL_COMMAND_LAYER_DEV, ZCL_COMMAND_SCOPE_LOCAL,
    ZCL_COMMAND_AUTH_OPERATOR, ZCL_COMMAND_LATENCY_INSTANT,
    ZCL_COMMAND_COST_LOW, ZCL_COMMAND_LANE_LOCAL,
    ZCL_COMMAND_CAP_DEV_STATE_READ,
    ZCL_COMMAND_TRAIT_IDEMPOTENT | ZCL_COMMAND_TRAIT_DEV_ONLY,
    ZCL_COMMAND_TRANSPORT_NATIVE, zcl_native_handle_dev_status)

ZCL_COMMAND_READY_READ(
    "dev.ff", "dev", "", "Fail-fast ladder: compile, test, lint",
    "Pass/fail result of a freshly executed compile+focused-test+lint "
    "ladder run synchronously against the current checkout via `make ff`; "
    "not cached, dev build only.", 0,
    "dev,ff,ladder,fast,verify", "zcl.command.empty_input.v1",
    "zcl.dev_ff.v1", "", "", "zclassic23 dev ff",
    ZCL_COMMAND_LAYER_DEV, ZCL_COMMAND_SCOPE_LOCAL,
    ZCL_COMMAND_AUTH_OPERATOR, ZCL_COMMAND_LATENCY_INSTANT,
    ZCL_COMMAND_COST_LOW, ZCL_COMMAND_LANE_LOCAL,
    ZCL_COMMAND_CAP_DEV_STATE_READ,
    ZCL_COMMAND_TRAIT_IDEMPOTENT | ZCL_COMMAND_TRAIT_DEV_ONLY,
    ZCL_COMMAND_TRANSPORT_NATIVE, zcl_native_handle_dev_ff)

ZCL_COMMAND_BRANCH("dev.core", "dev", "Core boundary and proof lanes",
                   ZCL_COMMAND_LAYER_DEV)
ZCL_COMMAND_BRANCH("dev.app", "dev", "Build capability-scoped C Apps",
