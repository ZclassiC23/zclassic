    "change,apply,build,hotswap,reload,rollback", "zcl.dev_change_input.v1",
    "zcl.dev_cycle.v1", "files", "", "zclassic23 dev change apply --input='{\"files\":[\"apps/social/app.def\"]}'",
    ZCL_COMMAND_EFFECT_MUTATE,
