ZCL_COMMAND_BRANCH("dev.vcs", "dev", "One-command source+binary revert",
                   ZCL_COMMAND_LAYER_DEV)

ZCL_COMMAND_DEV_COMMAND(
    "dev.vcs.revert", "dev.vcs", "", "Restore the checkout to a prior ZVCS "
    "commit; generation relinking is currently contained",
    "The forward ZVCS commit id and reverted-to commit id from an actual "
    "append-only source revert just applied to this checkout; generation "
    "relinking is always refused today.", 0,
    "vcs,revert,rollback,generation,relink", "zcl.dev_vcs_revert_input.v1",
    "zcl.dev_vcs_revert.v1", "to,relink_generation", "to",
    "zclassic23 dev vcs revert --input='{\"to\":\"<64-hex commit id>\","
    "\"relink_generation\":true}'",
    ZCL_COMMAND_EFFECT_MUTATE,
    ZCL_COMMAND_RISK_DEV_MUTATION, ZCL_COMMAND_SCOPE_DEV_LANE,
    ZCL_COMMAND_AUTH_OWNER, ZCL_COMMAND_MODE_SYNC,
    ZCL_COMMAND_LATENCY_FOREGROUND, ZCL_COMMAND_COST_HIGH,
    ZCL_COMMAND_CONFIRM_NONE, ZCL_COMMAND_LANE_DEV,
    ZCL_COMMAND_CAP_CHECKOUT_WRITE | ZCL_COMMAND_CAP_PROCESS_EXEC |
        ZCL_COMMAND_CAP_DEV_ACTIVATE,
    ZCL_COMMAND_TRAIT_DEV_ONLY | ZCL_COMMAND_TRAIT_REVERSIBLE,
    zcl_native_handle_dev_vcs_revert,
    "one-command source+binary revert requires a dev build",
    "zclassic23-dev dev vcs revert <to> [--relink-generation]")

