ZCL_COMMAND_BRANCH("dev.test", "dev", "Focused proof selection",
                   ZCL_COMMAND_LAYER_DEV)
ZCL_COMMAND_BRANCH("dev.generation", "dev", "Generation provenance",
                   ZCL_COMMAND_LAYER_DEV)
ZCL_COMMAND_BRANCH("dev.diagnose", "dev", "Failure capsule lookup",
                   ZCL_COMMAND_LAYER_DEV)

