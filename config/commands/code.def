/* Hierarchical source-code navigator. Local, read-only, deterministic leaves
 * backed by the in-binary lib/codeindex index (self-rebuilds on open if the
 * source tree is stale). Bounded output — a token-cheap alternative to reading
 * whole files. Native transport only. */

ZCL_COMMAND_BRANCH("code", "", "Hierarchical source-code navigator",
                   ZCL_COMMAND_LAYER_CODE)

ZCL_COMMAND_READY_READ(
    "code.group", "code", "",
    "List the top source groups, or one group's subgroups and files",
    "Subgroups and files of one navigator group (top groups when none given), "
    "from the in-binary code index which self-rebuilds if the tree is stale; "
    "complete for that group.", 0,
    "code,group,shape,module,map", "zcl.code_group_input.v1",
    "zcl.code_group.v1", "group", "group",
    "zclassic23 code group app/services",
    ZCL_COMMAND_LAYER_CODE, ZCL_COMMAND_SCOPE_LOCAL,
    ZCL_COMMAND_AUTH_PUBLIC, ZCL_COMMAND_LATENCY_FAST,
    ZCL_COMMAND_COST_TINY,
    ZCL_COMMAND_LANE_LOCAL | ZCL_COMMAND_LANE_ALL_NODE,
    ZCL_COMMAND_CAP_NONE,
    ZCL_COMMAND_TRAIT_DETERMINISTIC | ZCL_COMMAND_TRAIT_IDEMPOTENT,
    ZCL_COMMAND_TRANSPORT_NATIVE, zcl_native_handle_code_group)

ZCL_COMMAND_READY_READ(
    "code.map", "code", "",
    "Map the whole tree: the root groups (aggregate file counts) and app shapes",
    "The whole tree's root groups with aggregate file counts and the eight app "
    "shapes, from the in-binary code index; a complete overview at index-build "
    "time.", 0,
    "code,map,tree,overview,groups,shapes", "zcl.command.empty_input.v1",
    "zcl.code_map.v1", "", "",
    "zclassic23 code map",
    ZCL_COMMAND_LAYER_CODE, ZCL_COMMAND_SCOPE_LOCAL,
    ZCL_COMMAND_AUTH_PUBLIC, ZCL_COMMAND_LATENCY_FAST,
    ZCL_COMMAND_COST_TINY,
    ZCL_COMMAND_LANE_LOCAL | ZCL_COMMAND_LANE_ALL_NODE,
    ZCL_COMMAND_CAP_NONE,
    ZCL_COMMAND_TRAIT_DETERMINISTIC | ZCL_COMMAND_TRAIT_IDEMPOTENT,
    ZCL_COMMAND_TRANSPORT_NATIVE, zcl_native_handle_code_map)

ZCL_COMMAND_READY_READ(
    "code.tests", "code", "",
    "Show which focused test group a change to one file routes to",
    "The focused test group(s) a change to one file routes to, derived from the "
    "code index's file-to-proof mapping; deterministic, empty if the path maps "
    "to no focused group.", 0,
    "code,tests,route,impact,proof", "zcl.code_path_input.v1",
    "zcl.code_tests.v1", "path", "path",
    "zclassic23 code tests lib/net/src/download.c",
    ZCL_COMMAND_LAYER_CODE, ZCL_COMMAND_SCOPE_LOCAL,
    ZCL_COMMAND_AUTH_PUBLIC, ZCL_COMMAND_LATENCY_FAST,
    ZCL_COMMAND_COST_TINY,
    ZCL_COMMAND_LANE_LOCAL | ZCL_COMMAND_LANE_ALL_NODE,
    ZCL_COMMAND_CAP_NONE,
    ZCL_COMMAND_TRAIT_DETERMINISTIC | ZCL_COMMAND_TRAIT_IDEMPOTENT,
    ZCL_COMMAND_TRANSPORT_NATIVE, zcl_native_handle_code_tests)

ZCL_COMMAND_READY_READ(
    "code.room", "code", "",
    "Compose shape, purpose, group+neighbors and tests/route for one path",
    "One path's shape, purpose, group with sibling neighbors, and test route "
    "composed from the in-binary code index; complete for that path at "
    "index-build time.", 0,
    "code,room,shape,neighbors,tests,unified", "zcl.code_path_input.v1",
    "zcl.code_room.v1", "path", "path",
    "zclassic23 code room app/jobs/src/utxo_apply_stage.c",
    ZCL_COMMAND_LAYER_CODE, ZCL_COMMAND_SCOPE_LOCAL,
    ZCL_COMMAND_AUTH_PUBLIC, ZCL_COMMAND_LATENCY_FAST,
    ZCL_COMMAND_COST_TINY,
    ZCL_COMMAND_LANE_LOCAL | ZCL_COMMAND_LANE_ALL_NODE,
    ZCL_COMMAND_CAP_NONE,
    ZCL_COMMAND_TRAIT_DETERMINISTIC | ZCL_COMMAND_TRAIT_IDEMPOTENT,
    ZCL_COMMAND_TRANSPORT_NATIVE, zcl_native_handle_code_room)

ZCL_COMMAND_READY_READ(
    "code.file", "code", "",
    "Show one file's symbol table and its in-tree include dependencies",
    "One file's symbol table and its in-tree include dependencies from the code "
    "index; complete for symbols the indexer parsed, in-tree includes only.", 0,
    "code,file,symbols,includes,deps", "zcl.code_path_input.v1",
    "zcl.code_file.v1", "path", "path",
    "zclassic23 code file lib/vcs/src/vcs_index.c",
    ZCL_COMMAND_LAYER_CODE, ZCL_COMMAND_SCOPE_LOCAL,
    ZCL_COMMAND_AUTH_PUBLIC, ZCL_COMMAND_LATENCY_FAST,
    ZCL_COMMAND_COST_TINY,
    ZCL_COMMAND_LANE_LOCAL | ZCL_COMMAND_LANE_ALL_NODE,
    ZCL_COMMAND_CAP_NONE,
    ZCL_COMMAND_TRAIT_DETERMINISTIC | ZCL_COMMAND_TRAIT_IDEMPOTENT,
    ZCL_COMMAND_TRANSPORT_NATIVE, zcl_native_handle_code_file)

ZCL_COMMAND_READY_READ(
    "code.sym", "code", "",
    "Show one symbol's card: kind, signature, def/decl, doc, guard, group",
    "One symbol's card — kind, signature, definition/declaration sites, doc, "
    "guard, and group — from the code index; complete for the symbol the "
    "indexer resolved.", 0,
    "code,symbol,signature,definition,card", "zcl.code_name_input.v1",
    "zcl.code_symbol.v1", "name", "name",
    "zclassic23 code sym codeindex_open",
    ZCL_COMMAND_LAYER_CODE, ZCL_COMMAND_SCOPE_LOCAL,
    ZCL_COMMAND_AUTH_PUBLIC, ZCL_COMMAND_LATENCY_FAST,
    ZCL_COMMAND_COST_TINY,
    ZCL_COMMAND_LANE_LOCAL | ZCL_COMMAND_LANE_ALL_NODE,
    ZCL_COMMAND_CAP_NONE,
    ZCL_COMMAND_TRAIT_DETERMINISTIC | ZCL_COMMAND_TRAIT_IDEMPOTENT,
    ZCL_COMMAND_TRANSPORT_NATIVE, zcl_native_handle_code_sym)

ZCL_COMMAND_READY_READ(
    "code.capsule", "code", "",
    "Compose one symbol's identity, call graph, includes, and command join",
    "One symbol's identity (id/def/decl/signature/group), direct callers and "
    "callees (each capped), in-tree includes of its def file, and the "
    "command paths whose registered handler is defined in that file, from "
    "the code index and the command handler index; budget-aware "
    "self-shrinking drops includes then callees then callers (never "
    "identity/def/route) to fit the reply budget — `dropped_sections` names "
    "what was cut.", 0,
    "code,capsule,symbol,callers,callees,commands,graph", "zcl.code_name_input.v1",
    "zcl.code_capsule.v1", "name", "name",
    "zclassic23 code capsule sovereignty_guard_allow",
    ZCL_COMMAND_LAYER_CODE, ZCL_COMMAND_SCOPE_LOCAL,
    ZCL_COMMAND_AUTH_PUBLIC, ZCL_COMMAND_LATENCY_FAST,
    ZCL_COMMAND_COST_TINY,
    ZCL_COMMAND_LANE_LOCAL | ZCL_COMMAND_LANE_ALL_NODE,
    ZCL_COMMAND_CAP_NONE,
    ZCL_COMMAND_TRAIT_DETERMINISTIC | ZCL_COMMAND_TRAIT_IDEMPOTENT,
    ZCL_COMMAND_TRANSPORT_NATIVE, zcl_native_handle_code_capsule)

ZCL_COMMAND_READY_READ(
    "code.refs", "code", "",
    "List bounded call sites and references to one symbol",
    "Call sites and references to one symbol from the code index, capped by "
    "`limit`; bounded — may be a partial view of all references when the cap is "
    "hit.", ZCL_COMMAND_LIST_BUDGET,
    "code,refs,callers,references,uses", "zcl.code_refs_input.v1",
    "zcl.code_refs.v1", "name,limit", "name",
    "zclassic23 code refs zcl_malloc",
    ZCL_COMMAND_LAYER_CODE, ZCL_COMMAND_SCOPE_LOCAL,
    ZCL_COMMAND_AUTH_PUBLIC, ZCL_COMMAND_LATENCY_FAST,
    ZCL_COMMAND_COST_TINY,
    ZCL_COMMAND_LANE_LOCAL | ZCL_COMMAND_LANE_ALL_NODE,
    ZCL_COMMAND_CAP_NONE,
    ZCL_COMMAND_TRAIT_DETERMINISTIC | ZCL_COMMAND_TRAIT_IDEMPOTENT,
    ZCL_COMMAND_TRANSPORT_NATIVE, zcl_native_handle_code_refs)

ZCL_COMMAND_READY_READ(
    "code.find", "code", "",
    "Rank at most N symbols by name, with a one-line context per hit",
    "At most `limit` symbols ranked by name match, one context line each, from "
    "the code index; a bounded ranked slice, not every match.",
    ZCL_COMMAND_LIST_BUDGET,
    "code,find,search,grep,symbol", "zcl.code_find_input.v1",
    "zcl.code_find.v1", "text,limit", "text",
    "zclassic23 code find hotswap",
    ZCL_COMMAND_LAYER_CODE, ZCL_COMMAND_SCOPE_LOCAL,
    ZCL_COMMAND_AUTH_PUBLIC, ZCL_COMMAND_LATENCY_FAST,
    ZCL_COMMAND_COST_TINY,
    ZCL_COMMAND_LANE_LOCAL | ZCL_COMMAND_LANE_ALL_NODE,
    ZCL_COMMAND_CAP_NONE,
    ZCL_COMMAND_TRAIT_DETERMINISTIC | ZCL_COMMAND_TRAIT_IDEMPOTENT,
    ZCL_COMMAND_TRANSPORT_NATIVE, zcl_native_handle_code_find)
