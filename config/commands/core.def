/* Consensus-bound Core capabilities (contract §5).
 *
 * READ-ONLY leaves that have a genuine live handler bind the generic native
 * bridge (zcl_native_bridge_command), which proxies the resolved leaf to the
 * one canonical MCP/RPC handler for this build. The path->tool binding lives in
 * the transport adapter (tools/command/native_command.c), never in this
 * metadata. Mutations and reads that are not yet bridged are PLANNED — the
 * engine fail-closes a PLANNED leaf with exit 3, so nothing is advertised as
 * working before its handler exists. Do NOT promote a handlerless node to
 * READY. */

ZCL_COMMAND_READY_READ(
    "core.status", "core", "", "Consensus node status: height, sync, health",
    "status,height,sync,consensus,tip", "zcl.command.empty_input.v1",
    "zcl.core_status.v1", "", "", "zclassic23 core status",
    ZCL_COMMAND_LAYER_CORE, ZCL_COMMAND_SCOPE_NODE, ZCL_COMMAND_AUTH_PUBLIC,
    ZCL_COMMAND_LATENCY_FAST, ZCL_COMMAND_COST_LOW,
    ZCL_COMMAND_LANE_LOCAL | ZCL_COMMAND_LANE_ALL_NODE,
    ZCL_COMMAND_CAP_CHAIN_READ,
    ZCL_COMMAND_TRAIT_IDEMPOTENT,
    ZCL_COMMAND_TRANSPORT_NATIVE, zcl_native_bridge_command)

ZCL_COMMAND_READY_READ(
    "core.status.brief", "core", "",
    "Flat lean status: hstar, gap, blocker, conditions, peers, rss "
    "(full field list: docs/NATIVE_COMMAND_INTERFACE.md CLI UX contract)",
    "status,brief,lean,flat,gap,serving,healthy", "zcl.command.empty_input.v1",
    "zcl.core_status_brief.v1", "", "", "zclassic23 core status brief",
    ZCL_COMMAND_LAYER_CORE, ZCL_COMMAND_SCOPE_NODE, ZCL_COMMAND_AUTH_PUBLIC,
    ZCL_COMMAND_LATENCY_FAST, ZCL_COMMAND_COST_LOW,
    ZCL_COMMAND_LANE_LOCAL | ZCL_COMMAND_LANE_ALL_NODE,
    ZCL_COMMAND_CAP_CHAIN_READ,
    ZCL_COMMAND_TRAIT_IDEMPOTENT,
    ZCL_COMMAND_TRANSPORT_NATIVE, zcl_native_bridge_command)

