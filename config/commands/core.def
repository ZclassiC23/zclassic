    "", "", "zclassic23 core storage stats",
    ZCL_COMMAND_LAYER_CORE, ZCL_COMMAND_SCOPE_NODE, ZCL_COMMAND_AUTH_OPERATOR,
    ZCL_COMMAND_LATENCY_FAST, ZCL_COMMAND_COST_LOW,
    ZCL_COMMAND_LANE_LOCAL | ZCL_COMMAND_LANE_ALL_NODE,
    ZCL_COMMAND_CAP_CHAIN_READ, ZCL_COMMAND_TRAIT_IDEMPOTENT,
    ZCL_COMMAND_TRANSPORT_NATIVE, zcl_native_bridge_command)
ZCL_COMMAND_PLANNED_READ(
    "core.storage.integrity", "core.storage", "",
    "Verify raw storage integrity",
    "Will report raw SQLite/storage integrity check results once a "
    "distinct handler is wired; today the handler is unbound and "
    "fails closed with exit 3.", 0,
    "storage,integrity,check",
    "zcl.command.empty_input.v1", "zcl.storage_integrity.v1", "", "",
    "zclassic23 core storage integrity",
    ZCL_COMMAND_LAYER_CORE, ZCL_COMMAND_SCOPE_NODE, ZCL_COMMAND_AUTH_OPERATOR,
    ZCL_COMMAND_LATENCY_FOREGROUND, ZCL_COMMAND_COST_MODERATE,
    ZCL_COMMAND_LANE_LOCAL | ZCL_COMMAND_LANE_ALL_NODE,
    ZCL_COMMAND_CAP_CHAIN_READ,
    "a distinct storage-integrity handler is a Wave 2.2 deliverable")
ZCL_COMMAND_READY_READ(
    "core.storage.query", "core.storage", "",
    "Run one SELECT-only query over node.db",
    "Raw SELECT-only query results read live from node.db at call "
