    "non-SELECT statements are rejected.", ZCL_COMMAND_LIST_BUDGET,
    "storage,query,sql,select",
    "zcl.core_storage_query.input.v1", "zcl.storage_query.v1", "sql,limit",
    "sql", "zclassic23 core storage query --sql='SELECT ...'",
    ZCL_COMMAND_LAYER_CORE, ZCL_COMMAND_SCOPE_NODE, ZCL_COMMAND_AUTH_OPERATOR,
    ZCL_COMMAND_LATENCY_FAST, ZCL_COMMAND_COST_MODERATE,
    ZCL_COMMAND_LANE_LOCAL | ZCL_COMMAND_LANE_ALL_NODE,
    ZCL_COMMAND_CAP_CHAIN_READ, ZCL_COMMAND_TRAIT_IDEMPOTENT,
    ZCL_COMMAND_TRANSPORT_NATIVE, zcl_native_bridge_command)

